<!DOCTYPE html>
<html>
<head>
  <title>Website Pribadi</title>
  <style>
    body {
      margin: 0;
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(120deg, #1e3c72, #2a5298);
      color: white;
    }

    nav {
      background: rgba(0,0,0,0.3);
      padding: 15px;
      text-align: center;
      position: sticky;
      top: 0;
    }

    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
    }

    nav a:hover {
      color: #ffd700;
    }

    section {
      padding: 60px 20px;
      text-align: center;
    }

    .card {
      background: rgba(255,255,255,0.1);
      padding: 20px;
      border-radius: 15px;
      backdrop-filter: blur(10px);
      margin: 20px auto;
      max-width: 600px;
    }

    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      max-width: 900px;
      margin: auto;
    }

    .gallery img {
      width: 100%;
      border-radius: 10px;
      transition: transform 0.3s;
    }

    .gallery img:hover {
      transform: scale(1.05);
    }

    video {
      width: 80%;
      border-radius: 10px;
    }
  </style>
</head>
<body>

  <nav>
    <a href="#home">Home</a>
    <a href="#biodata">Biodata</a>
    <a href="#galeri">Galeri</a>
    <a href="#video">Video</a>
  </nav>

  <!-- HOME -->
  <section id="home">
    <div class="card">
      <h1>Selamat Datang</h1>
      <p>Ini adalah website pribadi saya yang dibuat dengan HTML & CSS.</p>
    </div>
  </section>

  <!-- BIODATA -->
  <section id="biodata">
    <div class="card">
      <h2>Biodata</h2>
      <p>Nama: [Nama Anda]</p>
      <p>Umur: [Umur]</p>
      <p>Alamat: [Alamat]</p>
      <p>Hobi: [Hobi]</p>
    </div>
  </section>

  <!-- GALERI -->
  <section id="galeri">
    <h2>Galeri Foto</h2>
    <div class="gallery">
      <img src="https://via.placeholder.com/300">
      <img src="https://via.placeholder.com/300">
      <img src="https://via.placeholder.com/300">
      <img src="https://via.placeholder.com/300">
    </div>
  </section>

  <!-- VIDEO -->
  <section id="video">
    <h2>Video Saya</h2>
    <video controls>
      <source src="video.mp4" type="video/mp4">
      Browser tidak mendukung video.
    </video>
  </section>

</body>
</html>
